class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {

        int currentSum = 0;

        for (int i = 0; i < k; i++) {
            currentSum += nums[i];
        }

        double maxAvg = (double)currentSum / k;

        for (int i = k; i < nums.size(); i++) {

            currentSum = currentSum - nums[i - k];
            currentSum = currentSum + nums[i];

            double currentAvg = (double)currentSum / k;

            if (currentAvg > maxAvg) {
                maxAvg = currentAvg;
            }
        }

        return maxAvg;
    }
};
